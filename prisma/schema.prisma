// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url = env("DATABASE_URL")

}

model Base {
    id          String   @id @default(cuid())
    name        String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    createdById String
    createdBy   User     @relation("BaseCreatedBy", fields: [createdById], references: [id])
    tables      Table[]
}

model Table {
    id          String   @id @default(cuid())
    name        String
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    baseId      String
    base        Base     @relation(fields: [baseId], references: [id], onDelete: Cascade)
    createdById String
    createdBy   User     @relation("TableCreatedBy", fields: [createdById], references: [id])
    columns     Column[]
    rows        Row[]
    views       View[]
}

model Column {
    id          String   @id @default(cuid())
    name        String
    type        String 
    order       Int      @default(0)
    config      String?  
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    tableId     String
    table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
    createdById String
    createdBy   User     @relation("ColumnCreatedBy", fields: [createdById], references: [id])
    cells       Cell[]
}

model Row {
    id          String   @id @default(cuid())
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    tableId     String
    table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
    createdById String
    createdBy   User     @relation("RowCreatedBy", fields: [createdById], references: [id])
    cells       Cell[]
}

model Cell {
    id        String   @id @default(cuid())
    value     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    rowId     String
    row       Row      @relation(fields: [rowId], references: [id], onDelete: Cascade)
    columnId  String
    column    Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)

    @@unique([rowId, columnId])
}

model View {
    id          String        @id @default(cuid())
    name        String
    type        String
    order       Int           @default(0)
    config      String?
    searchQuery String?
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    tableId     String
    table       Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
    createdById String
    createdBy   User          @relation("ViewCreatedBy", fields: [createdById], references: [id])
    filters     ViewFilter[]
    sorts       ViewSort[]
    groups      ViewGroup[]
}

model ViewFilter {
    id          String   @id @default(cuid())
    columnId    String
    operator    String
    value       String?
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    viewId      String
    view        View     @relation(fields: [viewId], references: [id], onDelete: Cascade)
}

model ViewSort {
    id          String   @id @default(cuid())
    columnId    String
    direction   String   @default("asc")
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    viewId      String
    view        View     @relation(fields: [viewId], references: [id], onDelete: Cascade)
}

model ViewGroup {
    id          String   @id @default(cuid())
    columnId    String
    direction   String   @default("asc")
    order       Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    viewId      String
    view        View     @relation(fields: [viewId], references: [id], onDelete: Cascade)
}

model User {
    id             String   @id @default(cuid())
    name           String
    email          String   @unique
    hashedPassword String?
    image          String?
    role           String   @default("member")
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    bases          Base[]   @relation("BaseCreatedBy")
    tables         Table[]  @relation("TableCreatedBy")
    columns        Column[] @relation("ColumnCreatedBy")
    rows           Row[]    @relation("RowCreatedBy")
    views          View[]   @relation("ViewCreatedBy")
}
