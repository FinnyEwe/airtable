{
  "tailwindCSS.experimental.configFile": "src/styles/globals.css",
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "eslint.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  }
}
